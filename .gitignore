# Build artifacts
node_modules/
dist/
build/
target/
pkg/
*.wasm
*.tgz
*.d.ts.map
*.tsbuildinfo

# Cargo (Rust)
# packages/wasm/.gitignore tracks Cargo.lock explicitly; the root ignores
# build artifacts only.
**/Cargo.lock.bak

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
*.code-workspace

# Env / secrets
.env
.env.local
.env.*.local
*.key
*.pem
*.p12

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage / cache
coverage/
.nyc_output/
.eslintcache
.parcel-cache
.turbo
.cache

# Backups / merge artifacts
# Catches the *.bak files left behind by the BMad installer (visible via
# `git status` after the installer's first run) and the usual git merge
# residues.
*.bak
*.orig
*.rej

# Submodule residue
# vendor/contra/PINNED_VERSION is regenerated by `pnpm postinstall` and is
# intentionally NOT tracked. Files inside submodules ignore the parent's
# .gitignore, so we can't suppress it from here — this comment is the
# warning. If a fresh clone shows "Untracked content" under vendor/contra,
# that's the pin file and it is expected.

# Story 1.1b additions — Move build artifacts (Task 1)
move/build/

# Spike package — fixtures are committed; nothing to ignore at the package level.
