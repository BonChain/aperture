{
	"compilerOptions": {
		"target": "ES2022",
		"useDefineForClassFields": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"allowJs": true,
		"checkJs": false,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noEmit": true,
		"types": ["vitest/globals", "@testing-library/jest-dom"],
		"paths": {
			"@aperture/core": ["../../packages/core/src/index.ts"],
			"@aperture/core/proof": ["../../packages/core/src/proof/proofAdapter.ts"],
			"@aperture/core/crypto": ["../../packages/core/src/crypto/index.ts"]
		}
	},
	"include": ["src", "vite.config.ts"]
}
